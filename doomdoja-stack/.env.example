# Skopiuj ten plik do .env i dostosuj wartości
# cp .env.example .env

# Strefa czasowa
TZ=Europe/Warsaw

# SearxNG — zmień przed wystawieniem w sieci (nawet lokalnej)
SEARXNG_SECRET_KEY=doomdoja-local-only-not-public

# n8n — opcjonalne, jeśli chcesz basic auth
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=changeme
