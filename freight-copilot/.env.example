# Freight Copilot — environment template. Copy to .env and adjust.
# .env is git-ignored and MUST NOT be committed. Secrets never go in code/logs.

# --- Core ---
APP_NAME=Freight Copilot
APP_ENV=local
APP_TZ=Europe/Warsaw
DEFAULT_CURRENCY=EUR
DEFAULT_LANGUAGE=pl

# --- Database (SQLite default; set a Postgres DSN to switch) ---
# DATABASE_URL=postgresql+psycopg://freight:freight@localhost:5432/freight_copilot
DATABASE_URL=sqlite:///./freight_copilot.db

# --- Feature flags (SAFE defaults: external access OFF) ---
DEMO_MODE=true
EXTERNAL_READS_ENABLED=false
EXTERNAL_WRITES_ENABLED=false
TIMOCOM_ENABLED=false
TRANSEU_ENABLED=false
EMAIL_ENABLED=false
TRACKING_ENABLED=false
LOCAL_LLM_ENABLED=false
ANTHROPIC_LLM_ENABLED=false

# --- LLM provider (deterministic = no external LLM; product works fully) ---
# Options: deterministic (default) | mock (tests) | anthropic | local | auto
# LLM enriches drafts and intake parsing only; scores/risk/pricing stay
# deterministic, and every LLM call falls back to rules on any failure.
LLM_PROVIDER=deterministic
# To enable Anthropic: set the two lines below and provide ANTHROPIC_API_KEY.
# LLM_PROVIDER=anthropic
# ANTHROPIC_LLM_ENABLED=true
ANTHROPIC_PRIMARY_MODEL=claude-opus-4-8
ANTHROPIC_SUBAGENT_MODEL=claude-sonnet-4-6
# To enable a local OpenAI-compatible model (e.g. Ollama), keeping data on-box:
# LLM_PROVIDER=local
# LOCAL_LLM_ENABLED=true
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_MODEL=llama3.1

# --- Secrets (leave blank until authorised; never commit real values) ---
# TIMOCOM_API_KEY=
# TRANSEU_CLIENT_ID=
# TRANSEU_CLIENT_SECRET=
# ANTHROPIC_API_KEY=

# --- Routing / toll (offline by default; opt in to real routing) ---
# DISTANCE_PROVIDER: mock (offline geo estimate) | osrm (real driving distance) | manual
DISTANCE_PROVIDER=mock
OSRM_BASE_URL=https://router.project-osrm.org
# TOLL_PROVIDER: country_rate (per-country EUR/km estimate) | none
TOLL_PROVIDER=country_rate

# --- Upload safety ---
MAX_UPLOAD_BYTES=10485760
