# Przykład pliku .env — skopiuj do .env i uzupełnij wartości.
# Plik .env jest w .gitignore — NIGDY nie commituj kluczy.

# ── LOKALNY LLM (Ollama) ─────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
# DEFAULT_CODER_MODEL=deepseek-coder-v2:16b
# DEFAULT_FAST_MODEL=qwen2.5-coder:7b

# ── HYBRID ROUTER — Cloud fallback ───────────────────────────────────────────
# Ustaw aby włączyć eskalację do cloud dla złożonych zadań.
# Jeśli puste/nieobecne → router działa w trybie LOCAL-ONLY (bezpieczny default).
# Wygeneruj na: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── GITHUB AUTOMATION ────────────────────────────────────────────────────────
# Personal Access Token — wygeneruj na: https://github.com/settings/tokens/new
# Scope: repo (pełny dostęp). Zaczyna się od ghp_ lub github_pat_
# Alternatywnie: gh auth login (gh CLI) — wtedy tego pola nie potrzebujesz.
GITHUB_TOKEN=
# Format: owner/repo (np. lolopaolo511-sudo/doomdoja-ai)
GITHUB_REPO=lolopaolo511-sudo/doomdoja-ai

# ── USŁUGI ZEWNĘTRZNE ─────────────────────────────────────────────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

MAKE_API_TOKEN=
MAKE_WEBHOOK_URL=

SEARXNG_URL=http://localhost:8888
QDRANT_URL=http://localhost:6333
